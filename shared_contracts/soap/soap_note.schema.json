{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SOAP Note",
  "description": "Subjective, Objective, Assessment, Plan medical note",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier for the SOAP note"
    },
    "consultationId": {
      "type": "string",
      "description": "ID of the consultation this note belongs to"
    },
    "subjective": {
      "type": "string",
      "description": "Patient's reported symptoms and feelings"
    },
    "objective": {
      "type": "string",
      "description": "Observable facts and measurements"
    },
    "assessment": {
      "type": "string",
      "description": "Diagnosis or clinical impression"
    },
    "plan": {
      "type": "string",
      "description": "Treatment plan and next steps"
    }
  },
  "required": ["id", "consultationId"],
  "additionalProperties": false
}
